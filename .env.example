# Required at runtime
ROOM_PASSPHRASE=change-me
SQLCIPHER_KEY=64hex_chars_from_openssl_rand_-hex_32
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:you@example.com

# Optional, with defaults
PORT=3000
DB_PATH=./data.db
# Server-internal subpath. Leave empty if your reverse proxy strips the
# public prefix before forwarding (e.g. `tailscale funnel --set-path /chat`
# strips /chat). Set to /chat only if the proxy forwards the prefix as-is.
BASE_PATH=
# Public-facing subpath the BROWSER sees. Used in JSON image_url, push
# icon URLs, and the session cookie path. Must match VITE_BASE_PATH.
PUBLIC_BASE_PATH=
# Optional: serve a built client from this directory under BASE_PATH.
# In production, set this to <repo-root>/client/dist
STATIC_DIR=
# Frontend build-time public base path. Trailing slash required.
# Example: VITE_BASE_PATH=/chat/
VITE_BASE_PATH=/
